# =============================================================================
# DATABASE
# =============================================================================

# Full MongoDB connection string.
# - Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# - Local example:  mongodb://localhost:27017
MONGODB_URI=

# Identifier shown in MongoDB Atlas under "App Name" (monitoring purposes).
APP_NAME=

# Name of the database to use inside the MongoDB cluster.
DB_NAME=

# =============================================================================
# SERVER
# =============================================================================

# Port the Express server will listen on.
PORT=3001

# Runtime environment. Accepted values: development | production | test
NODE_ENV=development

# =============================================================================
# CORS
# =============================================================================

# URL(s) allowed to make cross-origin requests (typically your frontend).
# Separate multiple origins with commas, no spaces.
# Example: http://localhost:3000,https://myfrontend.com
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# ROUTES
# =============================================================================

# Comma-separated list of route groups to register.
# Remove a name to disable that group entirely without deleting its code.
# Available values: users, articles, auth (add more as needed)
ENABLE_ROUTES=auth,articles,users

# =============================================================================
# COOKIES
# =============================================================================

# Prevent client-side JavaScript from reading the cookie (recommended: true).
COOKIE_HTTP_ONLY=true

# SameSite policy. Values: Strict | Lax | None
# Use "None" only when frontend and backend are on different domains (requires COOKIE_SECURE=true).
COOKIE_SAME_SITE=None

# Send cookie only over HTTPS (required when COOKIE_SAME_SITE=None).
COOKIE_SECURE=true

# Cookie max-age in milliseconds.
# 315576000000 ms = 10 years (used for long-lived refresh-token cookies).
COOKIE_TIME_EXPIRATION=315576000000

# =============================================================================
# JWT
# =============================================================================

# How long the refresh token stays valid. Uses zeit/ms format: 10y, 30d, 1h…
JWT_REFRESH_EXPIRATION=1y

# Secret used to sign and verify JWTs. Must be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: never commit the real value to version control.
JWT_SECRET=